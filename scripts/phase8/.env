# ============================================================================
# Phase 8 - Nova RPC and Tooling - Test Suite Environment
# ============================================================================
# Working .env for the Ethernova devnet. The PowerShell runner loads this
# automatically before invoking any node script. Private keys are LEFT BLANK
# on purpose - fill them in locally and never commit a .env with secrets.
#
# Layout: KEY=value, one per line. # = comment.
# ============================================================================

# ----------------------------------------------------------------------------
# Required - primary node under test
# ----------------------------------------------------------------------------
PHASE8_RPC_URL=http://127.0.0.1:8545
PHASE8_CHAIN_ID=121526

# ----------------------------------------------------------------------------
# Multi-RPC consistency (Scenario S)
# Enables cross-node hash/state agreement checks against the live observer.
# ----------------------------------------------------------------------------
PHASE8_ENABLE_MULTI_RPC=true
PHASE8_NODE1_RPC=http://127.0.0.1:8545
PHASE8_NODE2_RPC=https://devrpc.ethnova.net
PHASE8_NODE3_RPC=

# ----------------------------------------------------------------------------
# Fixture creation (optional)
# Set PHASE8_PRIVATE_KEY_A to a funded devnet key to auto-mint Mailbox and
# ContentRef on every run. Session creation is intentionally skipped
# (see PHASE8_AUDIT.md - BUG-4 SDK stale).
# ----------------------------------------------------------------------------
PHASE8_ENABLE_FIXTURE_CREATION=true
PHASE8_PRIVATE_KEY_A=
PHASE8_PRIVATE_KEY_B=
PHASE8_PRIVATE_KEY_C=

# ----------------------------------------------------------------------------
# Existing on-chain fixtures (optional)
# If filled, drives positive-path lookups without minting fresh objects.
# fixture-creation will overwrite mailbox/contentRef entries on success.
# ----------------------------------------------------------------------------
PHASE8_EXISTING_SESSION_ID=
PHASE8_EXISTING_MAILBOX_ID=
PHASE8_EXISTING_CONTENT_REF_ID=
PHASE8_EXISTING_PROTOCOL_OBJECT_ID=

# ----------------------------------------------------------------------------
# Domain addresses (Scenarios L, M, Q)
# Domain 0 = any EOA without ef01/ef02 prefix
# Domain 1 = contract whose runtime bytecode starts with 0xef01
# Domain 2 = contract whose runtime bytecode starts with 0xef02
#
# AUTO-DEPLOY: if any of these are blank AND PHASE8_PRIVATE_KEY_A is set,
# the fixture creator deploys minimal stub contracts (runtime = prefix + STOP)
# and exports the resulting addresses. User-supplied values always win.
# Domain 0 defaults to the deployer EOA address if blank.
#
# Note: EOA addresses derived from extra private keys CANNOT be used for
# Domain 1 / Domain 2 - those domains are about contract code prefix, not
# account identity. Any EOA will always classify as Domain 0.
# ----------------------------------------------------------------------------
PHASE8_DOMAIN0_ADDRESS=
PHASE8_DOMAIN1_ADDRESS=
PHASE8_DOMAIN2_ADDRESS=

# ----------------------------------------------------------------------------
# Scenario toggles
# ----------------------------------------------------------------------------
PHASE8_ENABLE_SDK=true
PHASE8_ENABLE_HARDHAT_PLUGIN=true
PHASE8_ENABLE_LOAD_TEST=true

# ----------------------------------------------------------------------------
# Load test parameters (Scenario O)
# ----------------------------------------------------------------------------
PHASE8_LOAD_CONCURRENCY=50
PHASE8_LOAD_REQUESTS=500

# ----------------------------------------------------------------------------
# SDK / Plugin paths
# DEFAULTS work only if the test suite is extracted INTO your ethernova-devnet
# repo root (alongside devnet/nova-sdk/ and devnet/nova-hardhat-plugin/).
#
# If you extracted into a standalone folder (e.g. D:\Ethernova\...\p8\),
# set BOTH of these to the absolute path of the matching directories in
# your real ethernova-devnet checkout. Forward slashes work on Windows too.
#
# Example (Windows, absolute paths):
#   PHASE8_SDK_PATH=D:/Ethernova/ethernova-devnet/devnet/nova-sdk
#   PHASE8_PLUGIN_PATH=D:/Ethernova/ethernova-devnet/devnet/nova-hardhat-plugin
# ----------------------------------------------------------------------------
PHASE8_SDK_PATH=
PHASE8_PLUGIN_PATH=
PHASE8_HARDHAT_PROJECT=

# ----------------------------------------------------------------------------
# Reports
# Runner creates reports/phase8/real-usage/<timestamp>/ under PHASE8_REPORT_DIR
# and exports PHASE8_REPORT_DIR_RUN for the node scripts. Do not set
# PHASE8_REPORT_DIR_RUN by hand.
# ----------------------------------------------------------------------------
PHASE8_REPORT_DIR=reports/phase8/real-usage
