# =====================================================================
# Phase 5 — State Lifecycle Tiers Brutal Test Suite — Configuration
# =====================================================================
# Copy ke .env dan edit. Wajib isi PRIVATE_KEY di bawah.

# ---------------------------------------------------------------------
# Primary RPC — node yang dipake untuk send transaksi
# ---------------------------------------------------------------------
# Pilihan:
#   http://127.0.0.1:8545     - local node default port
#   http://127.0.0.1:8551     - kalau pakai topology multi-node
#   https://devrpc.ethnova.net - public devnet RPC (bisa, tapi slower)
#
# REKOMENDASI: pake node lokal lo, devrpc cuma di NODES list buat observer.
PRIMARY_RPC=http://127.0.0.1:8545
PRIMARY_CHAIN_ID=121526

# ---------------------------------------------------------------------
# Signer private key [WAJIB ISI]
# ---------------------------------------------------------------------
# Wallet ini perlu dana untuk:
#   - 50+ contract deployments
#   - Ratusan SLOAD/SSTORE transactions
#   - Concurrent burst stress test
# Minimum: 5 NOVA. Get dari faucet.ethnova.net.
# JANGAN paste mainnet key.
PRIVATE_KEY=

# ---------------------------------------------------------------------
# Consensus topology — 2+ node yang akan di-cross-check tiap transition
# ---------------------------------------------------------------------
# Format: Label1=URL1,Label2=URL2,...
# Default: lokal port 8545 + public devrpc (sesuai req lo: 2 node).
CONSENSUS_NODES=Local=http://127.0.0.1:8545,Devrpc=https://devrpc.ethnova.net

# Untuk full 4-node topology (kalau ada):
# CONSENSUS_NODES=M1=http://127.0.0.1:8551,M2=http://127.0.0.1:8552,O3=http://127.0.0.1:8553,O4=http://127.0.0.1:8554,Devrpc=https://devrpc.ethnova.net

# ---------------------------------------------------------------------
# Phase 5 thresholds (HARUS match params/ethernova/forks.go)
# ---------------------------------------------------------------------
# Test logic compute waktu wait dari sini. Kalo node beda nilai, preflight gagal.
ACTIVE_TIER_BLOCKS=10
WARM_TIER_BLOCKS=25
COLD_TIER_BLOCKS=50
WARMING_FEE_PER_BYTE=5

# ---------------------------------------------------------------------
# Brutal stress parameters
# ---------------------------------------------------------------------
STRESS_CONTRACTS=6
STRESS_SLOTS_PER_CONTRACT=2
STRESS_CONCURRENT_TX=12

# ---------------------------------------------------------------------
# Timing
# ---------------------------------------------------------------------
WAIT_BUFFER_BLOCKS=2
MAX_WAIT_SECONDS=18000

# ---------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------
REPORT_PATH=./report.json
VERBOSITY=1

# ---------------------------------------------------------------------
# Skip flags (untuk debug iterasi)
# ---------------------------------------------------------------------
SKIP_BRUTAL=0
SKIP_REGRESSION=0
SKIP_WITNESS=0
