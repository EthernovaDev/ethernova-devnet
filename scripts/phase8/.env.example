# Phase 8 - Nova RPC Namespace & Tooling - Test Suite environment.
# Copy this file to scripts/phase8/.env and fill in the values that apply.
# The PowerShell runner (run-phase8-real-usage-tests.ps1) loads this file
# automatically before invoking any node script. Lines starting with # are
# comments. Do NOT commit .env (it can contain private keys).

# ----- Required -----

# Primary RPC endpoint to target. Required for every scenario.
PHASE8_RPC_URL=http://127.0.0.1:8545

# Expected chain id (decimal). 121525 = mainnet-like, 121526 = devnet.
# The suite warns if the node reports a different chain id.
PHASE8_CHAIN_ID=121526

# ----- Multi-RPC consistency (Scenario S) -----
# Set PHASE8_ENABLE_MULTI_RPC=true and provide at least two of these to enable.
PHASE8_ENABLE_MULTI_RPC=false
PHASE8_NODE1_RPC=http://127.0.0.1:8545
PHASE8_NODE2_RPC=https://devrpc.ethnova.net
PHASE8_NODE3_RPC=

# ----- Fixture creation (optional) -----
# When enabled AND PHASE8_PRIVATE_KEY_A is set, the suite mints a Mailbox and
# a ContentRef and exports their IDs to PHASE8_EXISTING_MAILBOX_ID and
# PHASE8_EXISTING_CONTENT_REF_ID. Session creation is intentionally skipped
# (see PHASE8_AUDIT.md BUG-4). The script never invents precompile inputs.
PHASE8_ENABLE_FIXTURE_CREATION=true

# Hex-encoded private keys. KEY_A is the fixture creator; KEY_B is reserved
# for future session counterparty work; KEY_C is unused. NEVER commit real keys.
PHASE8_PRIVATE_KEY_A=
PHASE8_PRIVATE_KEY_B=
PHASE8_PRIVATE_KEY_C=

# ----- Existing on-chain fixtures (optional but recommended) -----
# Provide any of these to drive positive-path lookups without minting new
# objects. The fixture-creation step will overwrite the mailbox / content ref
# entries on success.
PHASE8_EXISTING_SESSION_ID=
PHASE8_EXISTING_MAILBOX_ID=
PHASE8_EXISTING_CONTENT_REF_ID=
PHASE8_EXISTING_PROTOCOL_OBJECT_ID=

# Domain addresses for hre.nova / nova:domain validation. Domain 0 is any EOA
# or contract without ef01/ef02 prefix; Domain 1 contracts have ef01-prefixed
# runtime; Domain 2 contracts have ef02-prefixed runtime. EOA addresses cannot
# be used for Domain 1/2 - those are about code prefix, not identity.
# If left blank and PHASE8_PRIVATE_KEY_A is set, the fixture creator
# auto-deploys minimal Domain 1 / Domain 2 stub contracts and exports the
# resulting addresses. Domain 0 defaults to the deployer EOA.
PHASE8_DOMAIN0_ADDRESS=
PHASE8_DOMAIN1_ADDRESS=
PHASE8_DOMAIN2_ADDRESS=

# ----- Scenario toggles -----
PHASE8_ENABLE_SDK=true
PHASE8_ENABLE_HARDHAT_PLUGIN=true
PHASE8_ENABLE_LOAD_TEST=true

# ----- Load test parameters (Scenario O) -----
PHASE8_LOAD_CONCURRENCY=50
PHASE8_LOAD_REQUESTS=500

# ----- SDK / Plugin paths -----
# DEFAULTS work only if the test suite is extracted INTO your ethernova-devnet
# repo root (alongside devnet/nova-sdk/ and devnet/nova-hardhat-plugin/).
# If you extracted into a standalone folder, set BOTH of these to the absolute
# path of the matching directories in your real ethernova-devnet checkout.
# Example (Windows): PHASE8_SDK_PATH=D:/Ethernova/ethernova-devnet/devnet/nova-sdk
PHASE8_SDK_PATH=
PHASE8_PLUGIN_PATH=
PHASE8_HARDHAT_PROJECT=

# ----- Reports -----
# Base directory for run artifacts. The runner creates a timestamped
# subdirectory under this path and sets PHASE8_REPORT_DIR_RUN for the node
# scripts to write into. You normally do NOT set PHASE8_REPORT_DIR_RUN
# yourself - it is exported by the runner.
PHASE8_REPORT_DIR=reports/phase8/real-usage
